# 🚀 UNIVERSAL SERVER CONFIGURATION

# Server Settings
SERVER_PORT=7070

# Database Settings (PostgreSQL)
DB_HOST=localhost:5432
DB_NAME=cruddb
DB_USER=user
DB_PASSWORD=YOUR_DATABASE_PASSWORD_HERE
DB_SSLMODE=disable

# Hibernate Settings
DB_DDL_AUTO=update
DB_SHOW_SQL=true

# Prototyping Mode (Set to true to use In-Memory H2 instead of Postgres)
USE_H2=false

# Security (JWT)
ISSUER=carebridge
TOKEN_EXPIRE_TIME=3600000
SECRET_KEY=YOUR_SECURE_SECRET_KEY_HERE
